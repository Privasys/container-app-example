{
    "tools": [
        {
            "name": "store",
            "description": "Write a value to the app's per-app sealed volume (/data). Survives restarts and upgrades; the host never sees the encryption key or the plaintext.",
            "endpoint": "/store",
            "inputSchema": {
                "type": "object",
                "properties": {
                    "key": {
                        "type": "string",
                        "description": "Key (alphanumerics, dot, dash, underscore; max 128 chars)."
                    },
                    "value": {
                        "type": "string",
                        "description": "Value to store."
                    }
                },
                "required": ["key", "value"]
            }
        },
        {
            "name": "fetch",
            "description": "Read a value previously written with `store` from the per-app sealed volume.",
            "endpoint": "/fetch",
            "inputSchema": {
                "type": "object",
                "properties": {
                    "key": {
                        "type": "string",
                        "description": "Key to read."
                    }
                },
                "required": ["key"]
            }
        }
    ]
}
